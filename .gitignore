.DS_Store
.env
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# Local data must not be committed or submitted.
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/processed/airbnb_features_latest.parquet

# Generated outputs.
outputs/figures/*
outputs/tables/*
!outputs/figures/.gitkeep
!outputs/tables/.gitkeep

# Report build artefacts.
report.aux
report.bbl
report.blg
report.fdb_latexmk
report.fls
report.log
report.out
report.run.xml
report.synctex.gz
report.toc
report/*.aux
report/*.bbl
report/*.bcf
report/*.blg
report/*.fdb_latexmk
report/*.fls
report/*.log
report/*.out
report/*.run.xml
report/*.synctex.gz
report/*.toc
